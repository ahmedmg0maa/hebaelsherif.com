rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Production hardening:
    // - Product CRUD does NOT depend on Firebase Storage.
    // - Paid access is delivered through secure server-side routes and signed URLs.
    // - Keep direct public storage access disabled by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
