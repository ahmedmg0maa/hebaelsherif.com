rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return isSignedIn() && request.auth.token.email is string ? request.auth.token.email : "";
    }

    function normalizedUserEmail() {
      return userEmail().lower();
    }

    function normalizedResourceEmail() {
      return resource.data.email is string ? resource.data.email.lower() : "";
    }

    function isOwnerByUid() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isOwnerByEmail() {
      return isSignedIn() && normalizedUserEmail() != "" && normalizedResourceEmail() == normalizedUserEmail();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isOwnerByUid() || isOwnerByEmail();
      allow create, update, delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isOwnerByUid() || isOwnerByEmail();
      allow create, update, delete: if false;
    }

    match /books/{bookId} {
      allow read: if resource.data.status == "active";
      allow create, update, delete: if false;
    }

    match /courses/{courseId} {
      allow read: if resource.data.status == "active";
      allow create, update, delete: if false;
    }

    match /messages/{messageId} {
      allow read, write: if false;
    }

    match /protected_access_logs/{logId} {
      allow read, write: if false;
    }

    match /protected_active_sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
